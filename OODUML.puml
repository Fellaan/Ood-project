    + removeProduct()

}

Class ProductApplicationService {
    + createProduct()
    + listProduct()
    + getDetails()
    + calculateImpact()

}



Interface ImpactCalculationStrategy {
    + calculateImpact()
}

Class SimpleSumStrategy {
    + calculateImpact()


