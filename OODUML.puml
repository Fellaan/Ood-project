ConsoleUI ..> ProductApplicationService : uses
ConsoleUI ..> MaterialApplicationService : uses
ConsoleUI ..> LoginService : uses
ProductApplicationService ..> MaterialApplicationService
ProductApplicationService"1" --* "1.." Product : PAS has products
MaterialApplicationService"1" --* "1.." Material : MAS has materials
ImpactCalculationStrategy <|-- SimpleSumStrategy : implements
ImpactCalculationStrategy <|-- WeightedByLifespanStrategy : implements
ProductApplicationService ..> ImpactCalculationStrategy
Product <-- RecyclingGuidance
LoginService --> Account
Product"1" *-- "1..*"Material
Repository <|-- accountRepository : implements
Repository <|-- materialRepository : implements
Repository <|-- productRepository : implements
Repository <|-- recyclingRepository : implements




