@startuml OODProject
title OODProject

Class ConsoleUI {
   + Menuloop()
   + readInput()
   + printOutput()

}

Class Main {
    Hello, i run things!

}

Class Material {
   + String name
   + RecyclingCategory : Category
   + int EnvironmentalImpact

}

Class MaterialManager {
    + Arraylist : Material[]
    + addMaterial()
    + removeMaterial()

}

Class MaterialApplicationService {
    + addMaterial()
    + listMaterials()
    + getDetails()

}


Class Product {
    + String name
    + RecyclingCategory : Category
