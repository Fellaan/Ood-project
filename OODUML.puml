@startuml OODProject
title OODProject

Class Main {
    Hello, i run things!

}
rectangle PresentationLayer {
Class ConsoleUI {
   + Menuloop()
   + readInput()
   + printOutput()

}
}
rectangle ApplicationLayer {
Class ProductApplicationService {
    + Arraylist : Product[]
    + createProduct()
    + listProduct()
    + getDetails()
    + calculateImpact()

}


Class LoginService {
    - Arraylist : Account[]
    + login()
    + logout()

}
Class MaterialApplicationService {
    + Arraylist : Material[]
    + addMaterial()
    + listMaterials()
    + getDetails()

}
}

rectangle DomainLayer {
Class Account {
    - username
    - password
    - accountPrivilages

}

Class Material {
   + String name
   + RecyclingCategory 
   + int EnvironmentalImpact

}

Class Product {
    + Arraylist : Material[]
    + String name 
    + int estimatedLifespan

}



Interface ImpactCalculationStrategy {
    + calculateImpact()
}

Class SimpleSumStrategy {
    + calculateImpact()


}

Class WeightedByLifespanStrategy {
    + calculateImpact()

}


Class RecyclingGuidance  {
    + buildSingleMaterialGuidance()
    + buildMixedMaterialGuidance()
    
}
}
rectangle Infrastructure {

interface Repository {
    + saveToFile()
    + loadFromFile()
}

class materialRepository {
    + saveToFile()
    + loadFromFile()
}
class productRepository {
    + saveToFile()
    + loadFromFile()
}
class accountRepository{
    + saveToFile()
    + loadFromFile()
}
class recyclingRepository {
    + saveToFile()
    + loadFromFile()
}
}
